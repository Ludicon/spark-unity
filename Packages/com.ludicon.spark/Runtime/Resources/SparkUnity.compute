// These pragmas must be at the top level, you cannot place them inside #if blocks.
#pragma use_dxc
#pragma target 6.2
#pragma multi_compile _ UNITY_DEVICE_SUPPORTS_NATIVE_16BIT
#pragma multi_compile _ SPK_USE_TEXTURE_GATHER

#define SPK_ENABLE_F16 UNITY_DEVICE_SUPPORTS_NATIVE_16BIT || SHADER_API_GLES3
#define SPK_ENABLE_F16x2 SPK_ENABLE_F16 && SPK_USE_TEXTURE_GATHER

// GLES3 workaround for the ETC2_RGB and ETC2_RGBA kernels using mediump. HLSLcc can't
// translate the min16int ternaries in these specific shaders. It emits
// "ERROR missing components in GetBitcastOp" into the generated GLSL, the driver
// then fails to compile the kernel.
#if (defined(FORMAT_ETC2_RGB) || defined(FORMAT_ETC2_RGBA)) && SHADER_API_GLES3
    #undef  SPK_ENABLE_F16
    #undef  SPK_ENABLE_F16x2
    #define SPK_ENABLE_F16   0
    #define SPK_ENABLE_F16x2 0
#endif



// Using 16x8 for maximum compatibility. Some devices have a limit of 128 threads per block.
#define SPK_BLOCK_DIM_X 16
#define SPK_BLOCK_DIM_Y 8

// @@ Maybe we could use Unity's real type directly?
#if SPK_ENABLE_F16 || SPK_ENABLE_F16x2
    #define SPK_FLOAT  half
    #define SPK_FLOAT2 half2
    #define SPK_FLOAT3 half3
    #define SPK_FLOAT4 half4

    // Unity does not understand the int16_t/uint16_t types, so remap them to min16 types instead.
    // Note, when enabling Native16Bit these are translated to native 16-bit types, without that
    // option these are translated to mediump / RelaxedPrecision.
    #define int16_t  min16int
    #define uint16_t min16uint
    #define int16_t2  min16int2
    #define uint16_t2 min16uint2
    #define int16_t3  min16int3
    #define uint16_t3 min16uint3
    #define int16_t4  min16int4
    #define uint16_t4 min16uint4
#else
    #define SPK_FLOAT  float
    #define SPK_FLOAT2 float2
    #define SPK_FLOAT3 float3
    #define SPK_FLOAT4 float4
#endif


#if SHADER_API_METAL
    #pragma disable_fastmath
#endif


#if defined(FORMAT_BC1_RGB) || defined(FORMAT_BC3_RGBA) || defined(FORMAT_BC4_R) || \
    defined(FORMAT_BC5_RG) || defined(FORMAT_BC7_RGB) || defined(FORMAT_BC7_RGBA)

    #if SPK_ENABLE_F16x2
        #include "shaders/libspark_bcn_f16x2-unity.min.hlsl"
    #elif SPK_ENABLE_F16
        #include "shaders/libspark_bcn_f16-unity.min.hlsl"
    #else
        #include "shaders/libspark_bcn_f32-unity.min.hlsl"
    #endif

#elif defined(FORMAT_ASTC_RGB) || defined(FORMAT_ASTC_RGBA)
    #if SPK_ENABLE_F16x2
        #include "shaders/libspark_astc_f16x2-unity.min.hlsl"
    #elif SPK_ENABLE_F16
        #include "shaders/libspark_astc_f16-unity.min.hlsl"
    #else
        #include "shaders/libspark_astc_f32-unity.min.hlsl"
    #endif
#else
    #if SPK_ENABLE_F16x2
        #include "shaders/libspark_etc_f16x2-unity.min.hlsl"
    #elif SPK_ENABLE_F16
        #include "shaders/libspark_etc_f16-unity.min.hlsl"
    #else
        #include "shaders/libspark_etc_f32-unity.min.hlsl"
    #endif
#endif


///////////////////////////////////
// Spark Kernels

#define JOIN2(a, b) a##b
#define KERNEL(kernel_name) JOIN2(kernel_, kernel_name)

#if defined(FORMAT_BC1_RGB) || defined(FORMAT_BC4_R) || defined(FORMAT_ETC2_RGB) || defined(FORMAT_EAC_R)
    #if SHADER_API_GLES3
        // GLES does not support the rg32ui image format qualifier, so we use rgba16ui instead.
        #define DST_FORMAT min16uint4
        #define pack(v) min16uint4((v).x & 0xFFFF, (v).x >> 16, (v).y & 0xFFFF, (v).y >> 16)
    #else
        #define DST_FORMAT uint2
        #define pack(v) (v)
    #endif
#else
    #define DST_FORMAT uint4
    #define pack(v) (v)
#endif


#if SHADER_API_GLES3 || SHADER_API_VULKAN
    #define GATHER(Color, samp, uv, offset_x, offset_y) \
        JOIN2(Gather,Color)(samp, uv + float2(offset_x, offset_y) * size_rcp)
#else
    #define GATHER(Color, samp, uv, offset_x, offset_y) \
        JOIN2(Gather,Color)(samp, uv, int2(offset_x, offset_y))
#endif


#if SPK_ENABLE_F16x2
    #define SPARK_KERNEL_R(kernel_name) \
        [numthreads(SPK_BLOCK_DIM_X, SPK_BLOCK_DIM_Y, 1)] \
        void KERNEL(kernel_name)(uint2 tid : SV_DispatchThreadID) { \
            uint2 dim = (uint2)_SrcSizeMip.xy; \
            uint mip = (uint)_SrcSizeMip.z; \
            uint2 block_dim = (dim + 3u) / 4u; \
            [branch] if (any(tid >= block_dim)) return; \
            half2 input_r[8]; \
            LoadTexelBlockR(_Src, sampler_Src, dim, tid, mip, input_r); \
            _Dst[tid] = pack(kernel_name(input_r)); \
        }

    #if SPK_ENABLE_TEXTURE_GATHER

        #define SPARK_KERNEL_RG2(kernel_name, function_name) \
            [numthreads(SPK_BLOCK_DIM_X, SPK_BLOCK_DIM_Y, 1)] \
            void KERNEL(kernel_name)(uint2 tid : SV_DispatchThreadID) { \
                uint2 dim = (uint2)_SrcSizeMip.xy; \
                uint mip = (uint)_SrcSizeMip.z; \
                uint2 block_dim = (dim + 3u) / 4u; \
                [branch] if (any(tid >= block_dim)) return; \
                half2 input_r[8]; \
                uint4 block; \
                do { \
                    LoadTexelBlockR(_Src, sampler_Src, dim, tid, mip, input_r); \
                    block.xy = function_name(input_r); \
                } while (block_dim.x == 0); \
                do { \
                    LoadTexelBlockG(_Src, sampler_Src, dim, tid, mip, input_r); \
                    block.zw = function_name(input_r); \
                } while (block_dim.x == 0); \
                _Dst[tid] = block; \
            }

    #else

        #define SPARK_KERNEL_RG2(kernel_name, function_name) \
            [numthreads(SPK_BLOCK_DIM_X, SPK_BLOCK_DIM_Y, 1)] \
            void KERNEL(kernel_name)(uint2 tid : SV_DispatchThreadID) { \
                uint2 dim = (uint2)_SrcSizeMip.xy; \
                uint mip = (uint)_SrcSizeMip.z; \
                uint2 block_dim = (dim + 3u) / 4u; \
                [branch] if (any(tid >= block_dim)) return; \
                half2 input_r[8]; \
                half2 input_g[8]; \
                LoadTexelBlockRG(_Src, sampler_Src, dim, tid, mip, input_r, input_g); \
                uint4 block; \
                do { \
                    block.xy = function_name(input_r); \
                } while (block_dim.x == 0); \
                do { \
                    block.zw = function_name(input_g); \
                } while (block_dim.x == 0); \
                _Dst[tid] = block; \
            }

    #endif

    #define SPARK_KERNEL_RGB(kernel_name) \
        [numthreads(SPK_BLOCK_DIM_X, SPK_BLOCK_DIM_Y, 1)] \
        void KERNEL(kernel_name)(uint2 tid : SV_DispatchThreadID) { \
            uint2 dim = (uint2)_SrcSizeMip.xy; \
            uint mip = (uint)_SrcSizeMip.z; \
            uint2 block_dim = (dim + 3u) / 4u; \
            [branch] if (any(tid >= block_dim)) return; \
            half2 input_rgb[24]; \
            LoadTexelBlockRGB(_Src, sampler_Src, dim, tid, mip, input_rgb); \
            _Dst[tid] = pack(kernel_name(input_rgb)); \
        }

    #define SPARK_KERNEL_RGBA(kernel_name) \
        [numthreads(SPK_BLOCK_DIM_X, SPK_BLOCK_DIM_Y, 1)] \
        void KERNEL(kernel_name)(uint2 tid : SV_DispatchThreadID) { \
            uint2 dim = (uint2)_SrcSizeMip.xy; \
            uint mip = (uint)_SrcSizeMip.z; \
            uint2 block_dim = (dim + 3u) / 4u; \
            [branch] if (any(tid >= block_dim)) return; \
            half2 input_rgba[32]; \
            LoadTexelBlockRGBA(_Src, sampler_Src, dim, tid, mip, input_rgba); \
            _Dst[tid] = kernel_name(input_rgba); \
        }
#else
    #define SPARK_KERNEL_R(kernel_name) \
        [numthreads(SPK_BLOCK_DIM_X, SPK_BLOCK_DIM_Y, 1)] \
        void KERNEL(kernel_name)(uint2 tid : SV_DispatchThreadID) { \
            uint2 dim = (uint2)_SrcSizeMip.xy; \
            uint mip = (uint)_SrcSizeMip.z; \
            uint2 block_dim = (dim + 3u) / 4u; \
            [branch] if (any(tid >= block_dim)) return; \
            SPK_FLOAT input_r[16]; \
            LoadTexelBlockR(_Src, sampler_Src, dim, tid, mip, input_r); \
            _Dst[tid] = pack(kernel_name(input_r)); \
        }

    #if SPK_ENABLE_TEXTURE_GATHER

        #define SPARK_KERNEL_RG2(kernel_name, function_name) \
            [numthreads(SPK_BLOCK_DIM_X, SPK_BLOCK_DIM_Y, 1)] \
            void KERNEL(kernel_name)(uint2 tid : SV_DispatchThreadID) { \
                uint2 dim = (uint2)_SrcSizeMip.xy; \
                uint mip = (uint)_SrcSizeMip.z; \
                uint2 block_dim = (dim + 3u) / 4u; \
                [branch] if (any(tid >= block_dim)) return; \
                SPK_FLOAT input_r[16]; \
                uint4 block; \
                do { \
                    LoadTexelBlockR(_Src, sampler_Src, dim, tid, mip, input_r); \
                    block.xy = function_name(input_r); \
                } while (block_dim.x == 0); \
                do { \
                    LoadTexelBlockG(_Src, sampler_Src, dim, tid, mip, input_r); \
                    block.zw = function_name(input_r); \
                } while (block_dim.x == 0); \
                _Dst[tid] = block; \
            }

    #else

        #define SPARK_KERNEL_RG2(kernel_name, function_name) \
            [numthreads(SPK_BLOCK_DIM_X, SPK_BLOCK_DIM_Y, 1)] \
            void KERNEL(kernel_name)(uint2 tid : SV_DispatchThreadID) { \
                uint2 dim = (uint2)_SrcSizeMip.xy; \
                uint mip = (uint)_SrcSizeMip.z; \
                uint2 block_dim = (dim + 3u) / 4u; \
                [branch] if (any(tid >= block_dim)) return; \
                SPK_FLOAT input_r[16]; \
                SPK_FLOAT input_g[16]; \
                LoadTexelBlockRG(_Src, sampler_Src, dim, tid, mip, input_r, input_g); \
                uint4 block; \
                do { \
                    block.xy = function_name(input_r); \
                } while (block_dim.x == 0); \
                do { \
                    block.zw = function_name(input_g); \
                } while (block_dim.x == 0); \
                _Dst[tid] = block; \
            }

    #endif

    #define SPARK_KERNEL_RGB(kernel_name) \
        [numthreads(SPK_BLOCK_DIM_X, SPK_BLOCK_DIM_Y, 1)] \
        void KERNEL(kernel_name)(uint2 tid : SV_DispatchThreadID) { \
            uint2 dim = (uint2)_SrcSizeMip.xy; \
            uint mip = (uint)_SrcSizeMip.z; \
            uint2 block_dim = (dim + 3u) / 4u; \
            [branch] if (any(tid >= block_dim)) return; \
            SPK_FLOAT3 input_rgb[16]; \
            LoadTexelBlockRGB(_Src, sampler_Src, dim, tid, mip, input_rgb); \
            _Dst[tid] = pack(kernel_name(input_rgb)); \
        }

    #define SPARK_KERNEL_RGBA(kernel_name) \
        [numthreads(SPK_BLOCK_DIM_X, SPK_BLOCK_DIM_Y, 1)] \
        void KERNEL(kernel_name)(uint2 tid : SV_DispatchThreadID) { \
            uint2 dim = (uint2)_SrcSizeMip.xy; \
            uint mip = (uint)_SrcSizeMip.z; \
            uint2 block_dim = (dim + 3u) / 4u; \
            [branch] if (any(tid >= block_dim)) return; \
            SPK_FLOAT4 input_rgba[16]; \
            LoadTexelBlockRGBA(_Src, sampler_Src, dim, tid, mip, input_rgba); \
            _Dst[tid] = kernel_name(input_rgba); \
        }
#endif

#if SPK_USE_TEXTURE_GATHER

#if SPK_ENABLE_F16x2
    void LoadTexelBlockR(Texture2D tex, SamplerState samp, uint2 dim, uint2 tid, uint mipLevel, out half2 r[8])
    {
        float2 size_rcp = rcp(float2(dim));
        float2 uv = float2(tid * 4u) * size_rcp + size_rcp;

        half4 r00 = tex.GATHER(Red, samp, uv, 0, 0); r[0] = r00.xy; r[1] = r00.zw;
        half4 r01 = tex.GATHER(Red, samp, uv, 2, 0); r[2] = r01.xy; r[3] = r01.zw;
        half4 r10 = tex.GATHER(Red, samp, uv, 0, 2); r[4] = r10.xy; r[5] = r10.zw;
        half4 r11 = tex.GATHER(Red, samp, uv, 2, 2); r[6] = r11.xy; r[7] = r11.zw;
    }

    void LoadTexelBlockG(Texture2D tex, SamplerState samp, uint2 dim, uint2 tid, uint mipLevel, out half2 g[8])
    {
        float2 size_rcp = rcp(float2(dim));
        float2 uv = float2(tid * 4u) * size_rcp + size_rcp;

        half4 g00 = tex.GATHER(Green, samp, uv, 0, 0); g[0] = g00.xy; g[1] = g00.zw;
        half4 g01 = tex.GATHER(Green, samp, uv, 2, 0); g[2] = g01.xy; g[3] = g01.zw;
        half4 g10 = tex.GATHER(Green, samp, uv, 0, 2); g[4] = g10.xy; g[5] = g10.zw;
        half4 g11 = tex.GATHER(Green, samp, uv, 2, 2); g[6] = g11.xy; g[7] = g11.zw;
    }

    void LoadTexelBlockRG(Texture2D tex, SamplerState samp, uint2 dim, uint2 tid, uint mipLevel, out half2 r[8], out half2 g[8])
    {
        float2 size_rcp = rcp(float2(dim));
        float2 uv = float2(tid * 4u) * size_rcp + size_rcp;

        half4 r00 = tex.GATHER(Red, samp, uv, 0, 0); r[0] = r00.xy; r[1] = r00.zw;
        half4 r01 = tex.GATHER(Red, samp, uv, 2, 0); r[2] = r01.xy; r[3] = r01.zw;
        half4 r10 = tex.GATHER(Red, samp, uv, 0, 2); r[4] = r10.xy; r[5] = r10.zw;
        half4 r11 = tex.GATHER(Red, samp, uv, 2, 2); r[6] = r11.xy; r[7] = r11.zw;

        half4 g00 = tex.GATHER(Green, samp, uv, 0, 0); g[0] = g00.xy; g[1] = g00.zw;
        half4 g01 = tex.GATHER(Green, samp, uv, 2, 0); g[2] = g01.xy; g[3] = g01.zw;
        half4 g10 = tex.GATHER(Green, samp, uv, 0, 2); g[4] = g10.xy; g[5] = g10.zw;
        half4 g11 = tex.GATHER(Green, samp, uv, 2, 2); g[6] = g11.xy; g[7] = g11.zw;
    }

    void LoadTexelBlockRGB(Texture2D tex, SamplerState samp, uint2 dim, uint2 tid, uint mipLevel, out half2 rgb[24])
    {
        float2 size_rcp = rcp(float2(dim));
        float2 uv = float2(tid * 4u) * size_rcp + size_rcp;

        half4 r00 = tex.GATHER(Red, samp, uv, 0, 0); rgb[0] = r00.xy; rgb[1] = r00.zw;
        half4 r01 = tex.GATHER(Red, samp, uv, 2, 0); rgb[2] = r01.xy; rgb[3] = r01.zw;
        half4 r10 = tex.GATHER(Red, samp, uv, 0, 2); rgb[4] = r10.xy; rgb[5] = r10.zw;
        half4 r11 = tex.GATHER(Red, samp, uv, 2, 2); rgb[6] = r11.xy; rgb[7] = r11.zw;

        half4 g00 = tex.GATHER(Green, samp, uv, 0, 0); rgb[8] = g00.xy; rgb[9] = g00.zw;
        half4 g01 = tex.GATHER(Green, samp, uv, 2, 0); rgb[10] = g01.xy; rgb[11] = g01.zw;
        half4 g10 = tex.GATHER(Green, samp, uv, 0, 2); rgb[12] = g10.xy; rgb[13] = g10.zw;
        half4 g11 = tex.GATHER(Green, samp, uv, 2, 2); rgb[14] = g11.xy; rgb[15] = g11.zw;

        half4 b00 = tex.GATHER(Blue, samp, uv, 0, 0); rgb[16] = b00.xy; rgb[17] = b00.zw;
        half4 b01 = tex.GATHER(Blue, samp, uv, 2, 0); rgb[18] = b01.xy; rgb[19] = b01.zw;
        half4 b10 = tex.GATHER(Blue, samp, uv, 0, 2); rgb[20] = b10.xy; rgb[21] = b10.zw;
        half4 b11 = tex.GATHER(Blue, samp, uv, 2, 2); rgb[22] = b11.xy; rgb[23] = b11.zw;
    }

    void LoadTexelBlockRGBA(Texture2D tex, SamplerState samp, uint2 dim, uint2 tid, uint mipLevel, out half2 rgba[32])
    {
        float2 size_rcp = rcp(float2(dim));
        float2 uv = float2(tid * 4u) * size_rcp + size_rcp;

        half4 r00 = tex.GATHER(Red, samp, uv, 0, 0); rgba[0] = r00.xy; rgba[1] = r00.zw;
        half4 r01 = tex.GATHER(Red, samp, uv, 2, 0); rgba[2] = r01.xy; rgba[3] = r01.zw;
        half4 r10 = tex.GATHER(Red, samp, uv, 0, 2); rgba[4] = r10.xy; rgba[5] = r10.zw;
        half4 r11 = tex.GATHER(Red, samp, uv, 2, 2); rgba[6] = r11.xy; rgba[7] = r11.zw;

        half4 g00 = tex.GATHER(Green, samp, uv, 0, 0); rgba[8] = g00.xy; rgba[9] = g00.zw;
        half4 g01 = tex.GATHER(Green, samp, uv, 2, 0); rgba[10] = g01.xy; rgba[11] = g01.zw;
        half4 g10 = tex.GATHER(Green, samp, uv, 0, 2); rgba[12] = g10.xy; rgba[13] = g10.zw;
        half4 g11 = tex.GATHER(Green, samp, uv, 2, 2); rgba[14] = g11.xy; rgba[15] = g11.zw;

        half4 b00 = tex.GATHER(Blue, samp, uv, 0, 0); rgba[16] = b00.xy; rgba[17] = b00.zw;
        half4 b01 = tex.GATHER(Blue, samp, uv, 2, 0); rgba[18] = b01.xy; rgba[19] = b01.zw;
        half4 b10 = tex.GATHER(Blue, samp, uv, 0, 2); rgba[20] = b10.xy; rgba[21] = b10.zw;
        half4 b11 = tex.GATHER(Blue, samp, uv, 2, 2); rgba[22] = b11.xy; rgba[23] = b11.zw;


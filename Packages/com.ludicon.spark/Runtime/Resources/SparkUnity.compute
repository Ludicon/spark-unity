    lin[12] = tex.Load(base_coord, int2(0, 3));
    lin[13] = tex.Load(base_coord, int2(1, 3));
    lin[14] = tex.Load(base_coord, int2(2, 3));
    lin[15] = tex.Load(base_coord, int2(3, 3));

    rgba[ 0] = half2(lin[ 4].r, lin[ 5].r);  rgba[ 1] = half2(lin[ 1].r, lin[ 0].r);
    rgba[ 2] = half2(lin[ 6].r, lin[ 7].r);  rgba[ 3] = half2(lin[ 3].r, lin[ 2].r);
    rgba[ 4] = half2(lin[12].r, lin[13].r);  rgba[ 5] = half2(lin[ 9].r, lin[ 8].r);
    rgba[ 6] = half2(lin[14].r, lin[15].r);  rgba[ 7] = half2(lin[11].r, lin[10].r);

    rgba[ 8] = half2(lin[ 4].g, lin[ 5].g);  rgba[ 9] = half2(lin[ 1].g, lin[ 0].g);
    rgba[10] = half2(lin[ 6].g, lin[ 7].g);  rgba[11] = half2(lin[ 3].g, lin[ 2].g);
    rgba[12] = half2(lin[12].g, lin[13].g);  rgba[13] = half2(lin[ 9].g, lin[ 8].g);
    rgba[14] = half2(lin[14].g, lin[15].g);  rgba[15] = half2(lin[11].g, lin[10].g);

    rgba[16] = half2(lin[ 4].b, lin[ 5].b);  rgba[17] = half2(lin[ 1].b, lin[ 0].b);
    rgba[18] = half2(lin[ 6].b, lin[ 7].b);  rgba[19] = half2(lin[ 3].b, lin[ 2].b);
    rgba[20] = half2(lin[12].b, lin[13].b);  rgba[21] = half2(lin[ 9].b, lin[ 8].b);
    rgba[22] = half2(lin[14].b, lin[15].b);  rgba[23] = half2(lin[11].b, lin[10].b);

    rgba[24] = half2(lin[ 4].a, lin[ 5].a);  rgba[25] = half2(lin[ 1].a, lin[ 0].a);
    rgba[26] = half2(lin[ 6].a, lin[ 7].a);  rgba[27] = half2(lin[ 3].a, lin[ 2].a);
    rgba[28] = half2(lin[12].a, lin[13].a);  rgba[29] = half2(lin[ 9].a, lin[ 8].a);
    rgba[30] = half2(lin[14].a, lin[15].a);  rgba[31] = half2(lin[11].a, lin[10].a);
}

#else // SPK_ENABLE_F16x2

void LoadTexelBlockR(Texture2D tex, SamplerState samp, uint2 dim, uint2 tid, uint mipLevel, out SPK_FLOAT r[16])
{
    int3 base_coord = int3(tid * 4u, mipLevel);

    r[ 0] = tex.Load(base_coord, int2(0, 0)).r;
    r[ 1] = tex.Load(base_coord, int2(1, 0)).r;
    r[ 2] = tex.Load(base_coord, int2(2, 0)).r;
    r[ 3] = tex.Load(base_coord, int2(3, 0)).r;

    r[ 4] = tex.Load(base_coord, int2(0, 1)).r;
    r[ 5] = tex.Load(base_coord, int2(1, 1)).r;
    r[ 6] = tex.Load(base_coord, int2(2, 1)).r;
    r[ 7] = tex.Load(base_coord, int2(3, 1)).r;

    r[ 8] = tex.Load(base_coord, int2(0, 2)).r;
    r[ 9] = tex.Load(base_coord, int2(1, 2)).r;
    r[10] = tex.Load(base_coord, int2(2, 2)).r;
    r[11] = tex.Load(base_coord, int2(3, 2)).r;

    r[12] = tex.Load(base_coord, int2(0, 3)).r;
    r[13] = tex.Load(base_coord, int2(1, 3)).r;
    r[14] = tex.Load(base_coord, int2(2, 3)).r;
    r[15] = tex.Load(base_coord, int2(3, 3)).r;
}

void LoadTexelBlockRG(Texture2D tex, SamplerState samp, uint2 dim, uint2 tid, uint mipLevel, out SPK_FLOAT r[16], out SPK_FLOAT g[16])
{
    int3 base_coord = int3(tid * 4u, mipLevel);

    SPK_FLOAT2 rg[16];

    rg[ 0] = tex.Load(base_coord, int2(0, 0)).g;
    rg[ 1] = tex.Load(base_coord, int2(1, 0)).g;
    rg[ 2] = tex.Load(base_coord, int2(2, 0)).g;
    rg[ 3] = tex.Load(base_coord, int2(3, 0)).g;

    rg[ 4] = tex.Load(base_coord, int2(0, 1)).g;
    rg[ 5] = tex.Load(base_coord, int2(1, 1)).g;
    rg[ 6] = tex.Load(base_coord, int2(2, 1)).g;
    rg[ 7] = tex.Load(base_coord, int2(3, 1)).g;

    rg[ 8] = tex.Load(base_coord, int2(0, 2)).g;
    rg[ 9] = tex.Load(base_coord, int2(1, 2)).g;
    rg[10] = tex.Load(base_coord, int2(2, 2)).g;
    rg[11] = tex.Load(base_coord, int2(3, 2)).g;

    rg[12] = tex.Load(base_coord, int2(0, 3)).g;
    rg[13] = tex.Load(base_coord, int2(1, 3)).g;
    rg[14] = tex.Load(base_coord, int2(2, 3)).g;
    rg[15] = tex.Load(base_coord, int2(3, 3)).g;

    [unroll] for (int i = 0; i < 16; i++) {
        r[i] = rg[i].x;
        g[i] = rg[i].y;
    }
}

void LoadTexelBlockRGB(Texture2D tex, SamplerState samp, uint2 dim, uint2 tid, uint mipLevel, out SPK_FLOAT3 rgb[16])
{
    int3 base_coord = int3(tid * 4u, mipLevel);

    rgb[ 0] = tex.Load(base_coord, int2(0, 0)).rgb;
    rgb[ 1] = tex.Load(base_coord, int2(1, 0)).rgb;
    rgb[ 2] = tex.Load(base_coord, int2(2, 0)).rgb;
    rgb[ 3] = tex.Load(base_coord, int2(3, 0)).rgb;

    rgb[ 4] = tex.Load(base_coord, int2(0, 1)).rgb;
    rgb[ 5] = tex.Load(base_coord, int2(1, 1)).rgb;
    rgb[ 6] = tex.Load(base_coord, int2(2, 1)).rgb;
    rgb[ 7] = tex.Load(base_coord, int2(3, 1)).rgb;

    rgb[ 8] = tex.Load(base_coord, int2(0, 2)).rgb;
    rgb[ 9] = tex.Load(base_coord, int2(1, 2)).rgb;
    rgb[10] = tex.Load(base_coord, int2(2, 2)).rgb;
    rgb[11] = tex.Load(base_coord, int2(3, 2)).rgb;

    rgb[12] = tex.Load(base_coord, int2(0, 3)).rgb;
    rgb[13] = tex.Load(base_coord, int2(1, 3)).rgb;
    rgb[14] = tex.Load(base_coord, int2(2, 3)).rgb;
    rgb[15] = tex.Load(base_coord, int2(3, 3)).rgb;
}

void LoadTexelBlockRGBA(Texture2D tex, SamplerState samp, uint2 dim, uint2 tid, uint mipLevel, out SPK_FLOAT4 rgba[16])
{
    int3 base_coord = int3(tid * 4u, mipLevel);

    rgba[ 0] = tex.Load(base_coord, int2(0, 0));
    rgba[ 1] = tex.Load(base_coord, int2(1, 0));
    rgba[ 2] = tex.Load(base_coord, int2(2, 0));
    rgba[ 3] = tex.Load(base_coord, int2(3, 0));

    rgba[ 4] = tex.Load(base_coord, int2(0, 1));
    rgba[ 5] = tex.Load(base_coord, int2(1, 1));
    rgba[ 6] = tex.Load(base_coord, int2(2, 1));
    rgba[ 7] = tex.Load(base_coord, int2(3, 1));

    rgba[ 8] = tex.Load(base_coord, int2(0, 2));
    rgba[ 9] = tex.Load(base_coord, int2(1, 2));
    rgba[10] = tex.Load(base_coord, int2(2, 2));
    rgba[11] = tex.Load(base_coord, int2(3, 2));

    rgba[12] = tex.Load(base_coord, int2(0, 3));
    rgba[13] = tex.Load(base_coord, int2(1, 3));
    rgba[14] = tex.Load(base_coord, int2(2, 3));
    rgba[15] = tex.Load(base_coord, int2(3, 3));
}

#endif // SPK_ENABLE_F16x2


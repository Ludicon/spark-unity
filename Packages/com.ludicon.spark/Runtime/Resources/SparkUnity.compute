        SPK_FLOAT4 r01 = tex.GATHER(Red, samp, uv, 2, 0);
        SPK_FLOAT4 r10 = tex.GATHER(Red, samp, uv, 0, 2);
        SPK_FLOAT4 r11 = tex.GATHER(Red, samp, uv, 2, 2);

        rgb[0].x  = r00.w; rgb[1].x  = r00.z;   rgb[2].x  = r01.w; rgb[3].x  = r01.z;
        rgb[4].x  = r00.x; rgb[5].x  = r00.y;   rgb[6].x  = r01.x; rgb[7].x  = r01.y;
        rgb[8].x  = r10.w; rgb[9].x  = r10.z;   rgb[10].x = r11.w; rgb[11].x = r11.z;
        rgb[12].x = r10.x; rgb[13].x = r10.y;   rgb[14].x = r11.x; rgb[15].x = r11.y;

        SPK_FLOAT4 g00 = tex.GATHER(Green, samp, uv, 0, 0);
        SPK_FLOAT4 g01 = tex.GATHER(Green, samp, uv, 2, 0);
        SPK_FLOAT4 g10 = tex.GATHER(Green, samp, uv, 0, 2);
        SPK_FLOAT4 g11 = tex.GATHER(Green, samp, uv, 2, 2);

        rgb[0].y  = g00.w; rgb[1].y  = g00.z;   rgb[2].y  = g01.w; rgb[3].y  = g01.z;
        rgb[4].y  = g00.x; rgb[5].y  = g00.y;   rgb[6].y  = g01.x; rgb[7].y  = g01.y;
        rgb[8].y  = g10.w; rgb[9].y  = g10.z;   rgb[10].y = g11.w; rgb[11].y = g11.z;
        rgb[12].y = g10.x; rgb[13].y = g10.y;   rgb[14].y = g11.x; rgb[15].y = g11.y;

        SPK_FLOAT4 b00 = tex.GATHER(Blue, samp, uv, 0, 0);
        SPK_FLOAT4 b01 = tex.GATHER(Blue, samp, uv, 2, 0);
        SPK_FLOAT4 b10 = tex.GATHER(Blue, samp, uv, 0, 2);
        SPK_FLOAT4 b11 = tex.GATHER(Blue, samp, uv, 2, 2);

        rgb[0].z  = b00.w; rgb[1].z  = b00.z;   rgb[2].z  = b01.w; rgb[3].z  = b01.z;
        rgb[4].z  = b00.x; rgb[5].z  = b00.y;   rgb[6].z  = b01.x; rgb[7].z  = b01.y;
        rgb[8].z  = b10.w; rgb[9].z  = b10.z;   rgb[10].z = b11.w; rgb[11].z = b11.z;
        rgb[12].z = b10.x; rgb[13].z = b10.y;   rgb[14].z = b11.x; rgb[15].z = b11.y;
    }

    void LoadTexelBlockRGBA(Texture2D tex, SamplerState samp, uint2 dim, uint2 tid, uint mipLevel, out SPK_FLOAT4 rgba[16])
    {
        float2 size_rcp = rcp(float2(dim));

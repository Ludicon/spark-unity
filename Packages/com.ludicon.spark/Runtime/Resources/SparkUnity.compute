        SPK_FLOAT4 r01 = tex.GATHER(Red, samp, uv, 2, 0);
        SPK_FLOAT4 r10 = tex.GATHER(Red, samp, uv, 0, 2);
        SPK_FLOAT4 r11 = tex.GATHER(Red, samp, uv, 2, 2);

        rgba[0].x  = r00.w; rgba[1].x  = r00.z;   rgba[2].x  = r01.w; rgba[3].x  = r01.z;
        rgba[4].x  = r00.x; rgba[5].x  = r00.y;   rgba[6].x  = r01.x; rgba[7].x  = r01.y;
        rgba[8].x  = r10.w; rgba[9].x  = r10.z;   rgba[10].x = r11.w; rgba[11].x = r11.z;
        rgba[12].x = r10.x; rgba[13].x = r10.y;   rgba[14].x = r11.x; rgba[15].x = r11.y;

        SPK_FLOAT4 g00 = tex.GATHER(Green, samp, uv, 0, 0);
        SPK_FLOAT4 g01 = tex.GATHER(Green, samp, uv, 2, 0);
        SPK_FLOAT4 g10 = tex.GATHER(Green, samp, uv, 0, 2);
        SPK_FLOAT4 g11 = tex.GATHER(Green, samp, uv, 2, 2);

        rgba[0].y  = g00.w; rgba[1].y  = g00.z;   rgba[2].y  = g01.w; rgba[3].y  = g01.z;
        rgba[4].y  = g00.x; rgba[5].y  = g00.y;   rgba[6].y  = g01.x; rgba[7].y  = g01.y;
        rgba[8].y  = g10.w; rgba[9].y  = g10.z;   rgba[10].y = g11.w; rgba[11].y = g11.z;
        rgba[12].y = g10.x; rgba[13].y = g10.y;   rgba[14].y = g11.x; rgba[15].y = g11.y;

        SPK_FLOAT4 b00 = tex.GATHER(Blue, samp, uv, 0, 0);
        SPK_FLOAT4 b01 = tex.GATHER(Blue, samp, uv, 2, 0);
        SPK_FLOAT4 b10 = tex.GATHER(Blue, samp, uv, 0, 2);
        SPK_FLOAT4 b11 = tex.GATHER(Blue, samp, uv, 2, 2);

        rgba[0].z  = b00.w; rgba[1].z  = b00.z;   rgba[2].z  = b01.w; rgba[3].z  = b01.z;
        rgba[4].z  = b00.x; rgba[5].z  = b00.y;   rgba[6].z  = b01.x; rgba[7].z  = b01.y;
        rgba[8].z  = b10.w; rgba[9].z  = b10.z;   rgba[10].z = b11.w; rgba[11].z = b11.z;
        rgba[12].z = b10.x; rgba[13].z = b10.y;   rgba[14].z = b11.x; rgba[15].z = b11.y;

        SPK_FLOAT4 a00 = tex.GATHER(Alpha, samp, uv, 0, 0);
        SPK_FLOAT4 a01 = tex.GATHER(Alpha, samp, uv, 2, 0);
        SPK_FLOAT4 a10 = tex.GATHER(Alpha, samp, uv, 0, 2);
        SPK_FLOAT4 a11 = tex.GATHER(Alpha, samp, uv, 2, 2);

        rgba[0].w  = a00.w; rgba[1].w  = a00.z;   rgba[2].w  = a01.w; rgba[3].w  = a01.z;
        rgba[4].w  = a00.x; rgba[5].w  = a00.y;   rgba[6].w  = a01.x; rgba[7].w  = a01.y;
        rgba[8].w  = a10.w; rgba[9].w  = a10.z;   rgba[10].w = a11.w; rgba[11].w = a11.z;
        rgba[12].w = a10.x; rgba[13].w = a10.y;   rgba[14].w = a11.x; rgba[15].w = a11.y;
    }

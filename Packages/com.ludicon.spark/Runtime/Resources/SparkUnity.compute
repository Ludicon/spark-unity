        half4 a01 = tex.GATHER(Alpha, samp, uv, 2, 0); rgba[26] = a01.xy; rgba[27] = a01.zw;
        half4 a10 = tex.GATHER(Alpha, samp, uv, 0, 2); rgba[28] = a10.xy; rgba[29] = a10.zw;

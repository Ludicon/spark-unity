void LoadTexelBlockR(Texture2D tex, SamplerState samp, uint2 dim, uint2 tid, uint mipLevel, out half2 r[8])
{
    int3 base_coord = int3(tid * 4u, mipLevel);

    half lin[16];
    lin[ 0] = tex.Load(base_coord, int2(0, 0)).r;
    lin[ 1] = tex.Load(base_coord, int2(1, 0)).r;
    lin[ 2] = tex.Load(base_coord, int2(2, 0)).r;
    lin[ 3] = tex.Load(base_coord, int2(3, 0)).r;
    lin[ 4] = tex.Load(base_coord, int2(0, 1)).r;
    lin[ 5] = tex.Load(base_coord, int2(1, 1)).r;
    lin[ 6] = tex.Load(base_coord, int2(2, 1)).r;
    lin[ 7] = tex.Load(base_coord, int2(3, 1)).r;
    lin[ 8] = tex.Load(base_coord, int2(0, 2)).r;
    lin[ 9] = tex.Load(base_coord, int2(1, 2)).r;
    lin[10] = tex.Load(base_coord, int2(2, 2)).r;
    lin[11] = tex.Load(base_coord, int2(3, 2)).r;
    lin[12] = tex.Load(base_coord, int2(0, 3)).r;
    lin[13] = tex.Load(base_coord, int2(1, 3)).r;
    lin[14] = tex.Load(base_coord, int2(2, 3)).r;
    lin[15] = tex.Load(base_coord, int2(3, 3)).r;

    r[0] = half2(lin[ 4], lin[ 5]);  r[1] = half2(lin[ 1], lin[ 0]);
    r[2] = half2(lin[ 6], lin[ 7]);  r[3] = half2(lin[ 3], lin[ 2]);
    r[4] = half2(lin[12], lin[13]);  r[5] = half2(lin[ 9], lin[ 8]);
    r[6] = half2(lin[14], lin[15]);  r[7] = half2(lin[11], lin[10]);
}

